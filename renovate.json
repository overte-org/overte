{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "conan": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true
  },
  "includePaths": [
    "conanfile.py"
  ],
  "ignoreDeps": [
    "io",
    "com",
    "conan-io"
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "conan"
      ],
      "registryUrls": [
        "https://artifactory.overte.org/artifactory/api/conan/overte",
        "https://center.conan.io"
      ]
    }
  ]
}
