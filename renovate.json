{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "conan": {
    "enabled": true
  },
  "includePaths": [
    "conanfile.py"
  ],

  "packageRules": [
    {
      "matchDatasources": [ "conan" ],
      "registryUrls": [
        "https://artifactory.overte.org/artifactory/api/conan/overte",
        "https://center.conan.io"
      ],
      "maxMajorIncrement": 0,
      "lockFileMaintenance": { "enabled": true },
      "ignoreDeps": [
        "io",
        "com",
        "conan-io"
      ]
    }
  ]
}
